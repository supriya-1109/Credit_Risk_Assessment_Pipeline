    {
      "name": "abf15828",
      "displayName": "fact_loan_application",
      "queryLines": [
        "SELECT * FROM credits_catalog.gold_credit_risk_schema.fact_loan_application"
      ],
      "columns": [
        {
          "displayName": "risk_category",
          "description": "Risk category based on LTV (>0.9 High, >0.7 Medium) and DTI ratio (>43 High, >35 Medium)",
          "expression": "CASE\n  WHEN `LTV` > 0.9 OR `dtir1` > 43 THEN 'High'\n  WHEN `LTV` > 0.7 OR `dtir1` > 35 THEN 'Medium'\n  ELSE 'Low'\nEND"
        }
      ]
    },
    {
      "name": "6e2eeb23",
      "displayName": "Loan Default Analysis",
      "queryLines": [
        "SELECT\n",
        "  f.*,\n",
        "  l.loan_type,\n",
        "  l.loan_purpose\n",
        "FROM\n",
        "  credits_catalog.gold_credit_risk_schema.fact_loan_application f\n",
        "    JOIN credits_catalog.gold_credit_risk_schema.dim_loan l\n",
        "      ON f.loan_key = l.loan_key"
      ],
      "columns": [
        {
          "displayName": "application_status",
          "description": "Maps Status (0=Not Default, 1=Default) to readable labels",
          "expression": "CASE WHEN `Status` = 1 THEN 'Default' ELSE 'Not Default' END"
        },
        {
          "displayName": "risk_category",
          "description": "Risk category based on LTV and DTI ratio",
          "expression": "CASE\n  WHEN `LTV` > 0.9 OR `dtir1` > 43 THEN 'High'\n  WHEN `LTV` > 0.7 OR `dtir1` > 35 THEN 'Medium'\n  ELSE 'Low'\nEND"
        }
      ]
    },
    {
      "name": "6513c10d",
      "displayName": "Credit Score Analysis",
      "queryLines": [
        "SELECT\n",
        "  f.*,\n",
        "  c.Credit_Score,\n",
        "  c.open_credit\n",
        "FROM\n",
        "  credits_catalog.gold_credit_risk_schema.fact_loan_application f\n",
        "    JOIN credits_catalog.gold_credit_risk_schema.dim_credit c\n",
        "      ON f.credit_key = c.credit_key"
      ],
      "columns": [
        {
          "displayName": "risk_score",
          "description": "Composite risk score: 60% LTV + 40% DTI ratio, capped at 100",
          "expression": "ROUND(IF((`LTV` * 60) + (`dtir1` / 50 * 40) > 100, 100, (`LTV` * 60) + (`dtir1` / 50 * 40)), 2)"
        },
        {
          "displayName": "risk_category",
          "description": "Risk category based on LTV and DTI ratio",
          "expression": "CASE\n  WHEN `LTV` > 0.9 OR `dtir1` > 43 THEN 'High'\n  WHEN `LTV` > 0.7 OR `dtir1` > 35 THEN 'Medium'\n  ELSE 'Low'\nEND"
        }
      ]
    },
    {
      "name": "e798822b",
      "displayName": "Loan Performance",
      "queryLines": [
        "SELECT\n",
        "  f.*,\n",
        "  t.year\n",
        "FROM\n",
        "  credits_catalog.gold_credit_risk_schema.fact_loan_application f\n",
        "    JOIN credits_catalog.gold_credit_risk_schema.dim_time t\n",
        "      ON f.time_key = t.time_key"
      ]
    }
  ],
